---
import { ClientRouter } from 'astro:transitions';
import Font from 'astro/components/Font.astro';
import Topbar from '../components/Topbar.astro';

interface Props {
  title: string;
  description?: string;
  canonical?: string;
}

const {
  title,
  description = 'Browse upcoming real estate auctions in Massachusetts. Live bids, dates, deposits, and auctioneer details — updated daily.',
  canonical = Astro.url.href,
} = Astro.props;

const pageTitle =
  title === 'Auctions'
    ? 'Upcoming Property Auctions in Massachusetts | Auction Intel'
    : `${title} | Auction Intel`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    <!-- Primary SEO -->
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <!-- Open Graph -->
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />

    <!-- Astro 6 Fonts API — Satoshi (Fontshare) + JetBrains Mono (Fontsource) -->
    <Font cssVariable="--font-sans" preload />
    <Font cssVariable="--font-mono" preload />

    <!-- Early connection to FA CDN — saves DNS + TLS round-trips -->
    <link rel="preconnect" href="https://cdnjs.cloudflare.com" crossorigin />
    <link rel="dns-prefetch" href="https://cdnjs.cloudflare.com" />

    <!-- Preload the two FA woff2 subsets so they download in parallel with the CSS
         instead of chaining after it (saves ~594 ms on the critical path) -->
    <link
      rel="preload"
      as="font"
      type="font/woff2"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/webfonts/fa-solid-900.woff2"
      crossorigin
    />
    <link
      rel="preload"
      as="font"
      type="font/woff2"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/webfonts/fa-regular-400.woff2"
      crossorigin
    />

    <!-- Font Awesome — async (non-render-blocking).
         The preload trick: load as "style" triggers download without blocking render;
         onload swaps rel to "stylesheet" to apply it. noscript covers JS-off. -->
    <link
      rel="preload"
      as="style"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css"
      onload="this.onload=null;this.rel='stylesheet'"
    />
    <noscript>
      <link
        rel="stylesheet"
        href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css"
      />
    </noscript>

    <!-- Prevent icon flicker while FA loads async: hide .fa* elements until the
         stylesheet arrives, then fade them in. Runs inline before first paint. -->
    <style is:inline>
      .fas, .far, .fab { opacity: 0; transition: opacity 0.15s ease; }
    </style>
    <script is:inline>
      document.addEventListener('load', function onFaLoad(e) {
        if (e.target && e.target.href && e.target.href.includes('font-awesome')) {
          document.querySelectorAll('.fas,.far,.fab').forEach(function(el) {
            el.style.opacity = '';
          });
          document.removeEventListener('load', onFaLoad, true);
        }
      }, true);
    </script>

    <!-- SPA client routing -->
    <ClientRouter />

    <!--
      Zero-flicker dark mode: runs before first paint.
      Reads localStorage → prefers-color-scheme → defaults light.
    -->
    <script is:inline>
      (function () {
        const saved = localStorage.getItem('theme');
        const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        document.documentElement.setAttribute(
          'data-theme',
          saved || (prefersDark ? 'dark' : 'light')
        );
      })();
    </script>
  </head>
  <body>
    <Topbar />
    <main class="main-content">
      <slot />
    </main>
  </body>
</html>

<style is:global>
  /* ═══════════════════════════════════════════════════════
     LIGHT MODE — Zinc neutral palette
     All greys are Zinc values; accent is Deep Jade.
     Every text colour meets WCAG AA (4.5:1 on its background).
     ═══════════════════════════════════════════════════════ */
  :root {
    /* ── Surfaces ── */
    --color-bg:             #fafafa;   /* zinc-50  */
    --color-surface:        #ffffff;   /* white    */
    --color-surface-raised: #f4f4f5;   /* zinc-100 */
    --color-card:           var(--color-surface);

    /* ── Borders ── */
    --color-border:         #e4e4e7;   /* zinc-200 */
    --color-border-subtle:  #f4f4f5;   /* zinc-100 */

    /* ── Accent: Deep Jade (contrast ≥ 9:1 on white) ── */
    --color-accent:         hsl(160, 75%, 18%);
    --color-accent-dark:    hsl(160, 80%, 12%);
    --color-accent-light:   hsl(158, 58%, 48%);
    --color-accent-subtle:  hsl(160, 55%, 94%);   /* zinc-adjacent tint */

    /* ── Backward-compat aliases ── */
    --color-primary:        var(--color-accent);
    --color-primary-dark:   var(--color-accent-dark);
    --color-primary-light:  var(--color-accent-light);

    /* ── Text (all meet 4.5:1 on --color-surface) ──
       zinc-900 on white  ≈ 17:1   ✓
       zinc-600 on white  ≈  7:1   ✓
       zinc-500 on white  ≈  4.6:1 ✓ (passes AA)          */
    --color-text-primary:   #18181b;   /* zinc-900 */
    --color-text-secondary: #52525b;   /* zinc-600 — 7:1   */
    --color-text-muted:     #71717a;   /* zinc-500 — 4.6:1 */

    /* ── Status chips — zinc neutral + jade accent ── */
    --status-active-bg:     hsla(160, 75%, 18%, 0.07);
    --status-active-fg:     hsl(160, 75%, 16%);
    --status-active-border: hsla(160, 75%, 18%, 0.22);
    --status-postponed-bg:  hsla(38, 90%, 48%, 0.09);
    --status-postponed-fg:  hsl(32, 75%, 28%);
    --status-postponed-border: hsla(38, 90%, 48%, 0.28);
    --status-muted-bg:      #f4f4f5;   /* zinc-100 */
    --status-muted-fg:      #52525b;   /* zinc-600 */
    --status-muted-border:  #d4d4d8;   /* zinc-300 */

    /* ── Feedback colours ── */
    --color-success:  var(--color-accent);
    --color-danger:   #dc2626;   /* red-600  — 5.9:1 on white ✓ */
    --color-warning:  #d97706;   /* amber-600 — 4.6:1 on white ✓ */
    --color-info:     #2563eb;   /* blue-600  — 5.9:1 on white ✓ */
    --color-secondary: #52525b;

    /* ── Minimal shadows (border-first design) ── */
    --shadow-sm: 0 1px 2px 0 rgb(0 0 0 / 0.05);
    --shadow-md: 0 2px 6px -1px rgb(0 0 0 / 0.07);
    --shadow-lg: 0 8px 18px -3px rgb(0 0 0 / 0.09);
    --shadow-xl: 0 16px 28px -5px rgb(0 0 0 / 0.10);

    /* ── Typography ── */
    --font-sans: 'Satoshi', system-ui, -apple-system, sans-serif;
    --font-mono: 'JetBrains Mono', 'JetBrains Mono Variable', 'Courier New', Courier, monospace;

    /* ── Spacing ── */
    --spacing-xs:  0.5rem;
    --spacing-sm:  0.75rem;
    --spacing-md:  1rem;
    --spacing-lg:  1.5rem;
    --spacing-xl:  2rem;
    --spacing-2xl: 3rem;

    /* ── Radius — architectural / sharp ── */
    --radius-sm:   2px;
    --radius-md:   4px;
    --radius-lg:   6px;
    --radius-card: 2px;
    --radius-full: 9999px;

    /* ── Transitions ── */
    --transition-all: all 0.18s ease;
  }

  /* ═══════════════════════════════════════════════════════
     DARK MODE — [data-theme='dark']
     Zinc 950 base with Zinc 900 surface.
     Jade accent flips to a bright glow (mint green).
     Text: zinc-50/200/400 — all ≥ 4.5:1 on dark surface.
     ═══════════════════════════════════════════════════════ */
  [data-theme='dark'] {
    /* Surfaces */
    --color-bg:             #09090b;   /* zinc-950 */
    --color-surface:        #18181b;   /* zinc-900 */
    --color-surface-raised: #27272a;   /* zinc-800 */
    --color-card:           var(--color-surface);

    /* Borders */
    --color-border:         #3f3f46;   /* zinc-700 */
    --color-border-subtle:  #27272a;   /* zinc-800 */

    /* Accent — Jade Glow (neon mint) */
    --color-accent:         hsl(158, 60%, 52%);
    --color-accent-dark:    hsl(158, 60%, 42%);
    --color-accent-light:   hsl(158, 68%, 64%);
    --color-accent-subtle:  hsla(158, 60%, 52%, 0.12);

    /* Text (all ≥ 4.5:1 on zinc-900 #18181b)
       zinc-50  on zinc-900 ≈ 17:1  ✓
       zinc-400 on zinc-900 ≈  7:1  ✓
       zinc-500 on zinc-900 ≈  4.8:1 ✓                   */
    --color-text-primary:   #fafafa;   /* zinc-50  */
    --color-text-secondary: #a1a1aa;   /* zinc-400 — 7:1   */
    --color-text-muted:     #71717a;   /* zinc-500 — 4.8:1 */

    /* Status chips dark */
    --status-active-bg:     hsla(158, 60%, 52%, 0.12);
    --status-active-fg:     hsl(158, 60%, 62%);
    --status-active-border: hsla(158, 60%, 52%, 0.28);
    --status-postponed-bg:  hsla(38, 85%, 55%, 0.12);
    --status-postponed-fg:  hsl(38, 85%, 68%);
    --status-postponed-border: hsla(38, 85%, 55%, 0.28);
    --status-muted-bg:      #27272a;   /* zinc-800 */
    --status-muted-fg:      #a1a1aa;   /* zinc-400 */
    --status-muted-border:  #3f3f46;   /* zinc-700 */

    /* Shadows — heavier on dark */
    --shadow-sm: 0 1px 3px 0 rgb(0 0 0 / 0.4);
    --shadow-md: 0 4px 8px -1px rgb(0 0 0 / 0.5);
    --shadow-lg: 0 10px 20px -3px rgb(0 0 0 / 0.55);
    --shadow-xl: 0 20px 30px -5px rgb(0 0 0 / 0.6);
  }

  /* ── Reset ── */
  *, *::before, *::after {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  html {
    scroll-behavior: smooth;
    transition: background-color 0.25s ease, color 0.25s ease;
  }

  body {
    font-family: var(--font-sans);
    background-color: var(--color-bg);
    color: var(--color-text-primary);
    line-height: 1.5;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  /* Header: 0.625rem padding + ~44px bar + 0.625rem padding ≈ 4.5rem.
     Extra 0.75rem breathing room = 5.25rem total clearance.           */
  .main-content {
    padding-top: 5.25rem;
    min-height: 100vh;
  }

  /* ── Buttons ── */
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: var(--spacing-sm) var(--spacing-lg);
    font-weight: 600;
    border-radius: var(--radius-md);
    transition: var(--transition-all);
    cursor: pointer;
    border: none;
    font-size: 0.875rem;
    gap: var(--spacing-xs);
    letter-spacing: 0.01em;
    font-family: var(--font-sans);
  }

  .btn-primary {
    background-color: var(--color-accent);
    color: #fff;
  }

  .btn-primary:hover {
    background-color: var(--color-accent-dark);
  }

  .btn-secondary {
    background-color: var(--color-secondary);
    color: #fff;
  }

  .btn-secondary:hover {
    filter: brightness(90%);
  }

  /* ── Forms ── */
  .form-group {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-xs);
    margin-bottom: var(--spacing-md);
  }

  .form-label {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-text-secondary);
  }

  .form-control {
    padding: var(--spacing-sm);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    font-size: 1rem;
    transition: var(--transition-all);
    width: 100%;
    background-color: var(--color-surface);
    color: var(--color-text-primary);
    font-family: var(--font-sans);
  }

  .form-control:focus {
    outline: none;
    border-color: var(--color-accent);
    box-shadow: 0 0 0 3px var(--color-accent-subtle);
  }

  /* ── Cards — crisp border, no shadow, border-color hover ── */
  .card {
    background-color: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-card);
    transition: border-color 0.18s ease;
  }

  .card:hover {
    border-color: var(--color-accent);
  }

  /* ── Container / Grid ── */
  .container {
    width: 90%;
    max-width: 1200px;
    margin: 0 auto;
    padding: var(--spacing-md);
  }

  .grid {
    display: grid;
    gap: var(--spacing-lg);
  }

  /* ── Typography ── */
  h1, h2, h3, h4, h5, h6 {
    font-weight: 700;
    line-height: 1.2;
    letter-spacing: -0.02em;
    margin-bottom: var(--spacing-md);
  }

  h1 { font-size: 2.25rem; }
  h2 { font-size: 1.875rem; }
  h3 { font-size: 1.5rem; }
  h4 { font-size: 1.25rem; }
  h5 { font-size: 1.125rem; }
  h6 { font-size: 1rem; }

  a {
    color: inherit;
    text-decoration: none;
    transition: var(--transition-all);
  }

  /* ── Toast ── */
  .toast {
    position: fixed;
    bottom: var(--spacing-xl);
    left: 50%;
    transform: translateX(-50%) translateY(100%);
    background-color: var(--color-surface);
    border: 1px solid var(--color-border);
    padding: var(--spacing-md) var(--spacing-xl);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-lg);
    opacity: 0;
    transition: var(--transition-all);
    z-index: 1000;
    display: flex;
    align-items: center;
    gap: var(--spacing-sm);
    color: var(--color-text-primary);
    font-family: var(--font-mono);
    font-size: 0.8rem;
    letter-spacing: 0.02em;
    white-space: nowrap;
  }

  .toast.show {
    transform: translateX(-50%) translateY(0);
    opacity: 1;
  }

  .toast.success { border-left: 3px solid var(--color-success); }
  .toast.error   { border-left: 3px solid var(--color-danger); }
  .toast.info    { border-left: 3px solid var(--color-info); }

  /* ── Utilities ── */
  .text-center    { text-align: center; }
  .text-primary   { color: var(--color-accent); }
  .text-secondary { color: var(--color-text-secondary); }
  .font-bold      { font-weight: 700; }
  .mt-2           { margin-top: var(--spacing-md); }
  .mb-2           { margin-bottom: var(--spacing-md); }
</style>

---
import { Navbar, Nav } from "react-bootstrap";
const apiUrl = import.meta.env.API_URL;

---
<Navbar className="navbar" collapseOnSelect expand="md" bg="light" variant="light" fixed="top">
    <Navbar.Brand className="logo-nav-bar">
        <a href="/">
            <img alt="icon" class="d-inline-block" src="https://i.postimg.cc/KYyDL9CX/letters-icon-25.png" />
        </a>
    </Navbar.Brand>

    <Navbar.Collapse id="responsive-navbar-nav">
        <Nav className="ml-auto nav-home">
            <Nav.Link href="/" key="1" className="navbar-brand-text">Home</Nav.Link>
            <Nav.Link href="/favorites" key="2" className="navbar-brand-text">Favorites</Nav.Link>
            <Nav.Link href="/about" key="3" className="navbar-brand-text">About Us</Nav.Link>
            <div class="auth-links" id="authLinks">
                <Nav.Link href="/login" key="4" className="navbar-brand-text login-link">Login</Nav.Link>
                <Nav.Link href="/register" key="5" className="navbar-brand-text register-link">Register</Nav.Link>
              </div>
        </Nav>
    </Navbar.Collapse>
</Navbar>
<script define:vars={{ apiUrl }}>
const token = localStorage.getItem('jwt_token');
const authLinks = document.getElementById('authLinks');

// Update auth links based on token
if (token) {
    authLinks.innerHTML = `
        <a class="nav-link navbar-brand-text logout-link" href="#" onclick="handleLogout()">Logout</a>
    `;
} else {
    authLinks.innerHTML = `
        <a class="nav-link navbar-brand-text login-link" href="/login">Login</a>
        <a class="nav-link navbar-brand-text register-link" href="/register">Register</a>
    `;
}

async function handleLogout() {
    try {
        const response = await fetch(`${apiUrl}/auth/logout`, {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'Authorization': `Bearer ${localStorage.getItem('jwt_token')}`
            },
            credentials: 'include'
        });

        if (response.ok) {
            localStorage.removeItem('jwt_token');
            window.location.href = '/login';
        } else {
            console.error('Logout failed');
        }
    } catch (error) {
        console.error('Logout error:', error);
    }
}

// Make handleLogout available globally
window.handleLogout = handleLogout;
</script>
  
<style>
.navbar {
  width: 100%;
  background-color: #ffffff;
  box-shadow: 0px 2px 5px rgba(0, 0, 0, 0.1);
  z-index: 1000;
}

.d-inline-block {
  margin-left: 1rem;
  border-radius: 50%;
  width: 40px;
  height: 40px;
  object-fit: cover;
}

.logo-nav-bar {
  font-family: "Reenie Beanie", cursive;
  font-size: 2em;
  margin-left: 1rem;
}

.nav-home {
  margin-left: auto;
}

.navbar-brand-text {
  margin-right: 1.5rem;
  font-size: 1.2rem;
  font-weight: 400;
  color: #555;
  transition: color 0.3s ease;
}

.navbar-brand-text:hover {
  color: #007bff;
}
.auth-links {
    display: flex;
    gap: 1rem;
}

.login-link, .register-link, .logout-link {
    padding: 0.5rem 1rem;
    border-radius: 4px;
    transition: all 0.3s ease;
}

.login-link:hover, .register-link:hover, .logout-link:hover {
    background-color: #f8f9fa;
}
</style>
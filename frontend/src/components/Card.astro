---
interface Props {
  id: number;
  link: string;
  date: string;
  time: string;
  address: string;
  city: string;
  state: string;
  status: string;
  deposit: string;
  logo: string;
}

const { id, link, date, time: auctionTime, address, city, state, status, deposit, logo } =
  Astro.props;

// Convert "Apr 22, 2026" → "2026-04-22" for schema startDate
function toISODate(str: string): string {
  if (!str) return '';
  try {
    return new Date(str).toISOString().split('T')[0];
  } catch {
    return '';
  }
}

function statusCategory(s: string): 'active' | 'postponed' | 'muted' {
  const lower = s?.toLowerCase() ?? '';
  if (lower.includes('postponed')) return 'postponed';
  if (!s || lower === 'date tbd' || lower === 'tbd') return 'muted';
  return 'active';
}

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Event',
  name: `Property Auction: ${address}`,
  description: `Real estate auction at ${address}${city ? `, ${city}` : ''}${state ? `, ${state}` : ''}.`,
  startDate: toISODate(date) || undefined,
  location: {
    '@type': 'Place',
    name: address,
    address: {
      '@type': 'PostalAddress',
      streetAddress: address,
      addressLocality: city || undefined,
      addressRegion: state || 'MA',
      addressCountry: 'US',
    },
  },
  organizer: { '@type': 'Organization', logo: logo || undefined },
  eventStatus: 'https://schema.org/EventScheduled',
  eventAttendanceMode: 'https://schema.org/OfflineEventAttendanceMode',
  url: link || undefined,
};

// Escape </script> sequences to prevent early tag closure
const schemaJson = JSON.stringify(schema).replace(/</g, '\\u003c');

const statusCat = statusCategory(status);
const displayStatus = status || 'On Schedule';
---

<a
  href={link || '#'}
  target="_blank"
  rel="noopener noreferrer"
  class="card auction-card"
  aria-label={`View auction: ${address}`}
>
  <div class="card-body">

    <!-- Row 1: Status pill + auctioneer logo -->
    <div class="card-top">
      <span class="status-pill" data-status={statusCat}>{displayStatus}</span>
      {logo && <img src={logo} alt="" class="auctioneer-logo" loading="lazy" aria-hidden="true" />}
    </div>

    <!-- Row 2: Street address -->
    <h3 class="property-address">{address || 'Address not available'}</h3>

    <!-- Row 3: City / State -->
    {city && state && <p class="location-line">{city}, {state}</p>}

    <!-- Row 4: Terminal data block -->
    <div class="terminal-block">
      <div class="terminal-col">
        <span class="terminal-label">Date</span>
        <span class="terminal-value">{date || '—'}</span>
      </div>
      <div class="terminal-col">
        <span class="terminal-label">Time</span>
        {auctionTime
          ? <span class="terminal-value">{auctionTime}</span>
          : <span class="terminal-value terminal-value--tbd">TBD</span>}
      </div>
      <div class="terminal-col">
        <span class="terminal-label">Deposit</span>
        <span class="terminal-value">{deposit || '—'}</span>
      </div>
    </div>

    <!-- Footer: favorite button -->
    <div class="card-footer">
      <button
        class="favorite-btn"
        data-auction-id={id}
        data-loading="false"
        title="Add to favorites"
        aria-pressed="false"
        aria-label="Add to favorites"
      >
        <i class="far fa-heart"></i>
        <div class="fav-spinner"></div>
      </button>
    </div>

  </div>
</a>

<script type="application/ld+json" set:html={schemaJson} />

<style is:global>
  /* ── Card shell ── */
  .auction-card {
    display: flex;
    flex-direction: column;
    height: 100%;
    text-decoration: none;
    color: inherit;
    cursor: pointer;
    /* Override .card hover (no translate, just border color) */
    transition: border-color 0.2s ease;
  }

  .auction-card .card-body {
    padding: var(--spacing-lg);
    display: flex;
    flex-direction: column;
    gap: var(--spacing-sm);
    flex: 1;
  }

  /* ── Row 1: status + logo ── */
  .auction-card .card-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 2px;
  }

  /* Status pill — subtle, no glow */
  .auction-card .status-pill {
    display: inline-flex;
    align-items: center;
    padding: 2px 8px;
    border-radius: var(--radius-full);
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    border: 1px solid var(--status-active-border);
    background-color: var(--status-active-bg);
    color: var(--status-active-fg);
    white-space: nowrap;
    overflow: hidden;
    max-width: 160px;
    text-overflow: ellipsis;
    font-family: var(--font-mono);
  }

  .auction-card .status-pill[data-status='active'] {
    background-color: var(--status-active-bg);
    color: var(--status-active-fg);
    border-color: var(--status-active-border);
  }

  .auction-card .status-pill[data-status='postponed'] {
    background-color: var(--status-postponed-bg);
    color: var(--status-postponed-fg);
    border-color: var(--status-postponed-border);
  }

  .auction-card .status-pill[data-status='muted'] {
    background-color: var(--status-muted-bg);
    color: var(--status-muted-fg);
    border-color: var(--status-muted-border);
  }

  /* Auctioneer logo — small, grayscale */
  .auction-card .auctioneer-logo {
    width: 28px;
    height: 28px;
    border-radius: var(--radius-sm);
    object-fit: contain;
    border: 1px solid var(--color-border);
    background: var(--color-surface-raised);
    padding: 2px;
    flex-shrink: 0;
    filter: grayscale(100%);
    opacity: 0.7;
    transition: filter 0.2s ease, opacity 0.2s ease;
  }

  .auction-card:hover .auctioneer-logo {
    filter: grayscale(0%);
    opacity: 1;
  }

  /* ── Row 2: Address ── */
  .auction-card .property-address {
    font-size: 0.9375rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.3;
    color: var(--color-text-primary);
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* ── Row 3: Location ── */
  .auction-card .location-line {
    font-size: 0.775rem;
    color: var(--color-text-muted);
    letter-spacing: 0.02em;
    margin: 0;
    text-transform: uppercase;
    font-family: var(--font-mono);
  }

  /* ── Row 4: Terminal block ── */
  .auction-card .terminal-block {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    margin-top: auto;
    padding-top: var(--spacing-sm);
    border-top: 2px solid var(--color-accent);
  }

  .auction-card .terminal-col {
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding: 0 var(--spacing-sm);
    border-right: 1px solid var(--color-border);
  }

  .auction-card .terminal-col:first-child { padding-left: 0; }
  .auction-card .terminal-col:last-child  { border-right: none; }

  .auction-card .terminal-label {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-accent);
    line-height: 1;
  }

  .auction-card .terminal-value {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--color-text-primary);
    line-height: 1.2;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .auction-card .terminal-value--tbd {
    color: var(--color-text-muted);
    font-weight: 400;
    font-style: italic;
  }

  /* ── Footer: favorite button ── */
  .auction-card .card-footer {
    display: flex;
    justify-content: flex-end;
    padding-top: var(--spacing-xs);
  }

  .auction-card .favorite-btn {
    width: 1.75rem;
    height: 1.75rem;
    border-radius: var(--radius-sm);
    background: transparent;
    border: 1px solid var(--color-border);
    color: var(--color-text-muted);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.75rem;
    transition: var(--transition-all);
    position: relative;
    flex-shrink: 0;
  }

  .auction-card .favorite-btn:hover {
    background: var(--color-danger);
    color: white;
    border-color: var(--color-danger);
  }

  .auction-card .favorite-btn[aria-pressed='true'] {
    color: var(--color-danger);
    border-color: var(--color-danger);
  }

  .auction-card .favorite-btn[data-loading='true'] i {
    opacity: 0;
  }

  .auction-card .fav-spinner {
    display: none;
    position: absolute;
    width: 0.875rem;
    height: 0.875rem;
    border: 1.5px solid var(--color-border);
    border-radius: var(--radius-full);
    border-top-color: var(--color-accent);
    animation: fav-spin 0.6s linear infinite;
  }

  .auction-card .favorite-btn[data-loading='true'] .fav-spinner {
    display: block;
  }

  @keyframes fav-spin {
    to { transform: rotate(360deg); }
  }
</style>

---
interface Props {
    id: number;
    link: string;
    date: string;
    address: string;
    city: string;
    state: string;
    status: string;
    deposit: string;
    logo: string;
}

const { id, link, date, address, city, state, status, deposit, logo } = Astro.props;
const apiUrl = import.meta.env.VITE_API_URL;
---

<div class="card">
    <div class="card-header">
        <a href={link} target="_blank" rel="noopener noreferrer" class="card-logo">
            <img src={logo} class="thumb" alt="auction website logo" />
        </a>
        <button class="favorite-btn" data-auction-id={id} data-loading="false">
            <i class="far fa-heart"></i>
            <div class="loading-spinner"></div>
        </button>
    </div>
    <div class="status">{status || "On Schedule"}</div>
    <div class="date">Date: {date || "no date displayed"}</div>
    <div class="address">Address: {address || "no address displayed"}</div>
    {city && <div class="address">City: {city}</div>}
    {state && <div class="address">State: {state}</div>}
    <div class="deposit">Deposit: {deposit || "not available"}</div>
</div>

<script define:vars={{ apiUrl }}>
document.addEventListener('DOMContentLoaded', () => {
    const favoriteButtons = document.querySelectorAll('.favorite-btn');
    
    favoriteButtons.forEach(button => {
        button.addEventListener('click', async (e) => {
            e.preventDefault();
            
            if (!localStorage.getItem('jwt_token')) {
                window.location.href = '/login';
                return;
            }

            if (button.dataset.loading === 'true') return;

            const auctionId = parseInt(button.dataset.auctionId, 10);
            if (isNaN(auctionId)) {
                console.error('Invalid auction ID');
                return;
            }

            const icon = button.querySelector('i');
            const isFavorited = icon.classList.contains('fas');

            try {
                button.dataset.loading = 'true';
                const response = await fetch(`${apiUrl}/favorites/${isFavorited ? 'remove' : 'add'}`, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'Authorization': `Bearer ${localStorage.getItem('jwt_token')}`
                    },
                    body: JSON.stringify({ auction_id: auctionId }),
                    credentials: 'include'
                });

                if (response.ok) {
                    icon.classList.toggle('far');
                    icon.classList.toggle('fas');
                } else {
                    const data = await response.json();
                    console.error('Error:', data.message);
                    showToast('Error updating favorites');
                }
            } catch (error) {
                console.error('Error updating favorite:', error);
                showToast('Network error occurred');
            } finally {
                button.dataset.loading = 'false';
            }
        });
    });
});

function showToast(message) {
    const toast = document.createElement('div');
    toast.className = 'toast';
    toast.textContent = message;
    document.body.appendChild(toast);
    
    setTimeout(() => {
        toast.classList.add('show');
        setTimeout(() => {
            toast.classList.remove('show');
            setTimeout(() => {
                document.body.removeChild(toast);
            }, 300);
        }, 3000);
    }, 100);
}
</script>

<style>
  .card {
    margin-top: 20px;
    margin-left: auto;
    margin-right: auto;
    width: 100%;
    max-width: 380px;
    background-color: #ffffff;
    border-radius: 8px;
    box-shadow: 0px 4px 15px rgba(0, 0, 0, 0.1);
    overflow: hidden;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }
  
  .card:hover {
    transform: translateY(-5px);
    box-shadow: 0px 6px 20px rgba(0, 0, 0, 0.15);
  }
  
  .card-logo {
    display: block;
    text-align: center;
    padding: 1rem;
  }
  
  .thumb {
    width: 100%;
    height: 200px; /* Set a fixed height for consistency */
    object-fit: cover; /* Ensures the image scales properly without distortion */
    border-bottom: 1px solid #f0f0f0;
  }
  
  .status {
    font-size: 1.2rem;
    font-weight: bold;
    color: #007bff;
    margin: 1rem 0;
    text-align: center;
  }
  
  .date, .address, .deposit {
    font-size: 1rem;
    color: #555;
    margin: 0.5rem 1rem;
  }
  
  .deposit {
    font-weight: bold;
  }

.card-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1rem;
}

.favorite-btn {
    background: none;
    border: none;
    cursor: pointer;
    font-size: 1.5rem;
    color: #ff4b4b;
    transition: transform 0.2s ease;
    position: relative;
    padding: 0.5rem;
}

.favorite-btn[data-loading="true"] i {
    opacity: 0;
}

.favorite-btn[data-loading="true"] .loading-spinner {
    display: block;
}

.loading-spinner {
    display: none;
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 20px;
    height: 20px;
    border: 2px solid #ff4b4b;
    border-radius: 50%;
    border-top-color: transparent;
    animation: spin 0.6s linear infinite;
}

@keyframes spin {
    to {
        transform: translate(-50%, -50%) rotate(360deg);
    }
}

.toast {
    position: fixed;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%) translateY(100%);
    background-color: #333;
    color: white;
    padding: 12px 24px;
    border-radius: 4px;
    opacity: 0;
    transition: all 0.3s ease;
    z-index: 1000;
}

.toast.show {
    transform: translateX(-50%) translateY(0);
    opacity: 1;
}
  </style>
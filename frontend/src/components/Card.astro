---
import {Helmet} from "react-helmet";
const {repoData, link, date, address, status, city, state, deposit, logo} = Astro.props;
---

<div class="card">
    <Helmet>
      <meta name="title" content="" />
      <meta name="description" content="" />
      <script type="application/ld+json">
        {JSON.stringify({
          "@context": "https://schema.org",
          "@type": "RealEstateListing",
          name: `${id}`,
          image: `${logo ? logo : "No Image available"}`,
          address: {
            "@type": "PostalAddress",
            streetAddress: `${address ? address : "No address available"}`,
            addressLocality: `${city ? city : "No city available"} `,
            addressRegion: `${state ? state : "No state available"}`,
          },
          propertyID: `${id}`,
          propertyStatus: `${status ? status : "No status available"}`,
          availabilityStarts: `${date ? date : "No date available"}`,
          deposit: `${deposit ? deposit : "No deposit info"}`,
          url: `${link ? link : "No link available"}`,
        })}
      </script>
    </Helmet>
    <a href={link} target="blank" class="card-logo">
      <img src={logo} class="thumb" alt="image of auctioneer website logo" />
      <div class="status">{status ? status : "On Schedule"}</div>
      <div class="date">Date: {date ? date : "no date displayed"}</div>
      <div class="address">
        Address: {address ? address : "no address displayed"}
      </div>
      {city ? (
        <div class="address">City: {city ? city : null} </div>
      ) : null}
      {city ? (
        <div class="address">State: {state ? state : null} </div>
      ) : null}
      <div class="deposit">
        Deposit: {deposit ? deposit : "not available"}
      </div>
    </a>
</div>

<style>
  .card {
    margin-top: 20px;
    margin-left: auto;
    margin-right: auto;
    width: 100%;
    max-width: 380px;
    background-color: #ffffff;
    border-radius: 8px;
    box-shadow: 0px 4px 15px rgba(0, 0, 0, 0.1);
    overflow: hidden;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }
  
  .card:hover {
    transform: translateY(-5px);
    box-shadow: 0px 6px 20px rgba(0, 0, 0, 0.15);
  }
  
  .card-logo {
    display: block;
    text-align: center;
    padding: 1rem;
  }
  
  .thumb {
    width: 100%;
    height: 200px; /* Set a fixed height for consistency */
    object-fit: cover; /* Ensures the image scales properly without distortion */
    border-bottom: 1px solid #f0f0f0;
  }
  
  .status {
    font-size: 1.2rem;
    font-weight: bold;
    color: #007bff;
    margin: 1rem 0;
    text-align: center;
  }
  
  .date, .address, .deposit {
    font-size: 1rem;
    color: #555;
    margin: 0.5rem 1rem;
  }
  
  .deposit {
    font-weight: bold;
  }
  </style>
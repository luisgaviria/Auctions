---
interface Props {
  id: number;
  link: string;
  date: string;
  time: string;
  address: string;
  city: string;
  state: string;
  status: string;
  deposit: string;
  siteName: string;
  logo?: string;
}

const { id, link, date, time: auctionTime, address, city, state, status, deposit, siteName, logo } =
  Astro.props;

function toISODate(str: string): string {
  if (!str) return '';
  try { return new Date(str).toISOString().split('T')[0]; } catch { return ''; }
}

function statusCategory(s: string): 'active' | 'postponed' | 'muted' {
  const lower = s?.toLowerCase() ?? '';
  if (lower.includes('postponed')) return 'postponed';
  if (!s || lower === 'date tbd' || lower === 'tbd') return 'muted';
  return 'active';
}

function formatSiteName(s: string): string {
  if (!s) return '';
  return s.replace(/([a-z])([A-Z])/g, '$1 $2')
    .split(/[\s_-]+/)
    .map(w => w.charAt(0).toUpperCase() + w.slice(1).toLowerCase())
    .join(' ');
}

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Event',
  name: `Property Auction: ${address}`,
  description: `Real estate auction at ${address}${city ? `, ${city}` : ''}${state ? `, ${state}` : ''}.`,
  startDate: toISODate(date) || undefined,
  location: {
    '@type': 'Place',
    name: address,
    address: {
      '@type': 'PostalAddress',
      streetAddress: address,
      addressLocality: city || undefined,
      addressRegion: state || 'MA',
      addressCountry: 'US',
    },
  },
  organizer: { '@type': 'Organization', name: formatSiteName(siteName) || undefined },
  eventStatus: 'https://schema.org/EventScheduled',
  eventAttendanceMode: 'https://schema.org/OfflineEventAttendanceMode',
  url: link || undefined,
};

const schemaJson = JSON.stringify(schema).replace(/</g, '\\u003c');
const statusCat = statusCategory(status);
const displayStatus = status || 'On Schedule';
const displaySite = formatSiteName(siteName);
---

<a
  href={link || '#'}
  target="_blank"
  rel="noopener noreferrer"
  class="auction-card"
  aria-label={`View auction: ${address}`}
>
  <!-- Spotlight overlay — position driven by --mouse-x/--mouse-y via JS -->
  <div class="card-spotlight" aria-hidden="true"></div>

  <div class="card-inner">

    <!-- Header: status dot + auctioneer -->
    <div class="card-header">
      <div class="status-indicator" data-status={statusCat}>
        <span class="status-dot"></span>
        <span class="status-text">{displayStatus}</span>
      </div>
      {displaySite && <span class="auctioneer-label">{displaySite}</span>}
    </div>

    <!-- Address block -->
    <div class="card-address-block">
      <h3 class="property-address">{address || 'Address not available'}</h3>
      {city && state && <p class="location-line">{city}, {state}</p>}
    </div>

    <!-- Data row: value above label -->
    <div class="card-data-row">
      <div class="data-cell">
        <span class="data-value">{date || '—'}</span>
        <span class="data-label">Date</span>
      </div>
      <div class="data-cell">
        {auctionTime
          ? <span class="data-value">{auctionTime}</span>
          : <span class="data-value data-value--tbd">TBD</span>}
        <span class="data-label">Time</span>
      </div>
      <div class="data-cell">
        <span class="data-value">{deposit || '—'}</span>
        <span class="data-label">Deposit</span>
      </div>
    </div>

    <!-- Footer -->
    <div class="card-footer">
      <button
        class="favorite-btn"
        data-auction-id={id}
        data-loading="false"
        title="Add to favorites"
        aria-pressed="false"
        aria-label="Add to favorites"
      >
        <i class="far fa-heart"></i>
        <div class="fav-spinner"></div>
      </button>
    </div>

  </div>
</a>

<script type="application/ld+json" set:html={schemaJson} />

<!-- Mouse-follow spotlight — runs once per page, handles all cards -->
<script>
  if (!(window as any).__auctionCardSpotlightInit) {
    (window as any).__auctionCardSpotlightInit = true;
    document.addEventListener('mousemove', (e) => {
      const card = (e.target as Element).closest('.auction-card') as HTMLElement | null;
      if (!card) return;
      const r = card.getBoundingClientRect();
      card.style.setProperty('--mouse-x', `${e.clientX - r.left}px`);
      card.style.setProperty('--mouse-y', `${e.clientY - r.top}px`);
    });
  }
</script>

<style is:global>
  /* ═══════════════════════════════════════════════
     Auction Card — Vercel-style
     ═══════════════════════════════════════════════ */

  .auction-card {
    position: relative;
    display: flex;
    flex-direction: column;
    height: 100%;
    border-radius: 12px;
    border: 1px solid var(--color-border);
    background: var(--color-surface);
    text-decoration: none;
    color: inherit;
    overflow: hidden;
    transition: border-color 0.2s ease, transform 0.2s ease;
  }

  .auction-card:hover {
    border-color: var(--color-accent);
    transform: translateY(-2px);
  }

  /* Spotlight element kept in HTML but hidden — no background glow */
  .auction-card .card-spotlight { display: none; }

  .auction-card .card-inner {
    display: flex;
    flex-direction: column;
    flex: 1;
    padding: 1.375rem 1.375rem 1.125rem;
    gap: 1rem;
  }

  /* ── Header ── */
  .auction-card .card-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
  }

  .auction-card .status-indicator {
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }

  /* Colored dot */
  .auction-card .status-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    flex-shrink: 0;
    background: var(--color-text-muted);
  }

  .auction-card .status-indicator[data-status='active'] .status-dot {
    background: var(--color-accent);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--color-accent) 20%, transparent);
    animation: card-dot-pulse 2.4s ease-in-out infinite;
  }

  .auction-card .status-indicator[data-status='postponed'] .status-dot {
    background: var(--color-warning);
  }

  @keyframes card-dot-pulse {
    0%, 100% { box-shadow: 0 0 0 0 color-mix(in srgb, var(--color-accent) 40%, transparent); }
    50%       { box-shadow: 0 0 0 5px color-mix(in srgb, var(--color-accent) 0%, transparent); }
  }

  .auction-card .status-text {
    font-family: var(--font-mono);
    font-size: 0.625rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text-secondary);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    max-width: 140px;
  }

  .auction-card .status-indicator[data-status='active'] .status-text {
    color: var(--color-accent);
  }

  .auction-card .status-indicator[data-status='postponed'] .status-text {
    color: var(--color-warning);
  }

  /* Auctioneer name */
  .auction-card .auctioneer-label {
    font-family: var(--font-mono);
    font-size: 0.675rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    max-width: 100px;
    flex-shrink: 0;
  }

  /* ── Address block ── */
  .auction-card .card-address-block {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
    flex: 1;
  }

  .auction-card .property-address {
    font-size: 1.0625rem;
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.3;
    color: var(--color-text-primary);
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .auction-card .location-line {
    font-size: 14px;
    color: var(--color-text-muted);
    letter-spacing: 0.04em;
    text-transform: uppercase;
    font-weight: 700;
    font-family: var(--font-mono);
    margin: 0;
  }

  /* ── Data row ── */
  .auction-card .card-data-row {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    border-top: 1px solid var(--color-border);
    padding-top: 1rem;
    gap: 0;
    transition: border-color 0.2s ease;
  }

  .auction-card:hover .card-data-row {
    border-top-color: var(--color-accent);
  }

  .auction-card .data-cell {
    display: flex;
    flex-direction: column;
    gap: 5px;
    padding-right: 1rem;
    border-right: 1px solid var(--color-border);
  }

  .auction-card .data-cell:first-child { padding-left: 0; }
  .auction-card .data-cell:last-child  { border-right: none; padding-right: 0; padding-left: 1rem; }
  .auction-card .data-cell:not(:first-child):not(:last-child) { padding-left: 1rem; }

  .auction-card .data-value {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--color-text-primary);
    line-height: 1;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .auction-card .data-value--tbd {
    color: var(--color-text-muted);
    font-weight: 400;
    font-style: italic;
  }

  .auction-card .data-label {
    font-family: var(--font-mono);
    font-size: 0.675rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    line-height: 1;
  }

  /* ── Footer ── */
  .auction-card .card-footer {
    display: flex;
    justify-content: flex-end;
    padding-top: 0.25rem;
  }

  .auction-card .favorite-btn {
    width: 1.75rem;
    height: 1.75rem;
    border-radius: 6px;
    background: transparent;
    border: 1px solid var(--color-border);
    color: var(--color-text-muted);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.75rem;
    transition: all 0.15s ease;
    position: relative;
    flex-shrink: 0;
  }

  .auction-card .favorite-btn:hover {
    background: var(--color-danger);
    color: #fff;
    border-color: var(--color-danger);
  }

  .auction-card .favorite-btn[aria-pressed='true'] {
    color: var(--color-danger);
    border-color: var(--color-danger);
  }

  .auction-card .favorite-btn[data-loading='true'] i { opacity: 0; }

  .auction-card .fav-spinner {
    display: none;
    position: absolute;
    width: 0.875rem;
    height: 0.875rem;
    border: 1.5px solid var(--color-border);
    border-radius: 50%;
    border-top-color: var(--color-accent);
    animation: fav-spin 0.6s linear infinite;
  }

  .auction-card .favorite-btn[data-loading='true'] .fav-spinner { display: block; }

  @keyframes fav-spin { to { transform: rotate(360deg); } }
</style>

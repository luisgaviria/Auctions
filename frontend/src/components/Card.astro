---
const { link, date, address, city, state, status, deposit, logo, id } = Astro.props;
const apiUrl = import.meta.env.API_URL;
---

<div class="card">
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "http://schema.org",
    "@type": "Event",
    "name": "Auction",
    "startDate": date,
    "location": {
        "@type": "Place",
        "address": {
            "@type": "PostalAddress",
            "streetAddress": address,
            "addressLocality": city,
            "addressRegion": state
        }
    },
    "url": link || "No link available",
})}>
</script>
    <div class="card-header">
        <a href={link} target="blank" class="card-logo">
            <img src={logo} class="thumb" alt="image of auctioneer website logo" />
        </a>
        <button class="favorite-btn" data-auction-id={id}>
            <i class="far fa-heart"></i>
        </button>
    </div>
    <div class="status">{status ? status : "On Schedule"}</div>
    <div class="date">Date: {date ? date : "no date displayed"}</div>
    <div class="address">Address: {address ? address : "no address displayed"}</div>
    {city && <div class="address">City: {city}</div>}
    {state && <div class="address">State: {state}</div>}
    <div class="deposit">Deposit: {deposit ? deposit : "not available"}</div>
</div>

<script define:vars={{ apiUrl }}>
  document.addEventListener('DOMContentLoaded', () => {
      const favoriteButtons = document.querySelectorAll('.favorite-btn');
      
      favoriteButtons.forEach(button => {
          button.addEventListener('click', async (e) => {
              e.preventDefault();
              
              if (!localStorage.getItem('jwt_token')) {
                  window.location.href = '/login';
                  return;
              }
  
              const auctionId = button.dataset.auctionId;
              const icon = button.querySelector('i');
              const isFavorited = icon.classList.contains('fas');
  
              try {
                  const response = await fetch(`${apiUrl}/favorites/${isFavorited ? 'remove' : 'add'}`, {
                      method: 'POST',
                      headers: {
                          'Content-Type': 'application/json',
                          'Authorization': `Bearer ${localStorage.getItem('jwt_token')}`
                      },
                      body: JSON.stringify({ auction_id: auctionId }),
                      credentials: 'include'
                  });
  
                  if (response.ok) {
                      icon.classList.toggle('far');
                      icon.classList.toggle('fas');
                  }
              } catch (error) {
                  console.error('Error updating favorite:', error);
              }
          });
      });
  });
  </script>

<style>
  .card {
    margin-top: 20px;
    margin-left: auto;
    margin-right: auto;
    width: 100%;
    max-width: 380px;
    background-color: #ffffff;
    border-radius: 8px;
    box-shadow: 0px 4px 15px rgba(0, 0, 0, 0.1);
    overflow: hidden;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }
  
  .card:hover {
    transform: translateY(-5px);
    box-shadow: 0px 6px 20px rgba(0, 0, 0, 0.15);
  }
  
  .card-logo {
    display: block;
    text-align: center;
    padding: 1rem;
  }
  
  .thumb {
    width: 100%;
    height: 200px; /* Set a fixed height for consistency */
    object-fit: cover; /* Ensures the image scales properly without distortion */
    border-bottom: 1px solid #f0f0f0;
  }
  
  .status {
    font-size: 1.2rem;
    font-weight: bold;
    color: #007bff;
    margin: 1rem 0;
    text-align: center;
  }
  
  .date, .address, .deposit {
    font-size: 1rem;
    color: #555;
    margin: 0.5rem 1rem;
  }
  
  .deposit {
    font-weight: bold;
  }

.card-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1rem;
}

.favorite-btn {
    background: none;
    border: none;
    cursor: pointer;
    font-size: 1.5rem;
    color: #ff4b4b;
    transition: transform 0.2s ease;
}

.favorite-btn:hover {
    transform: scale(1.1);
}

.fas.fa-heart {
    color: #ff4b4b;
}
  </style>
    }

    .drawer-card-list {
      display: flex;
      flex-direction: column;
      gap: var(--spacing-md);
    }

    .drawer-load-more {
      display: flex;
      justify-content: center;
      padding: var(--spacing-sm) 0 var(--spacing-md);
    }
  }

  @media (max-width: 640px) {
    .page-header h1 {
      font-size: 1.875rem;
    }

    .card-grid {
      grid-template-columns: 1fr;
      gap: var(--spacing-md);
    }

    .view-toggle-btn {
      bottom: 1.25rem;
    }
  }
</style>

<!--
  Sidebar card overrides MUST be global: the .auction-card elements are injected via
  innerHTML (JS) and never receive Astro's scoped data attribute, so scoped selectors
  such as ".split-card-list .auction-card[data-astro-cid-xxx]" never match them.
-->
<style is:global>
  /* Ensure the sidebar panel has an opaque background so map tiles don't bleed through. */
  .split-left {
    background-color: var(--color-surface) !important;
  }

  /* Each injected card must size to its own content, not try to fill the sidebar height. */
  .split-card-list .auction-card {
    display: block !important;
    height: auto !important;
    min-height: 180px !important;
    margin-bottom: 1rem;
  }

  /* card-inner's global rule is flex:1 (flex-basis:0), which collapses to 0px without a
     definite parent height.  Restore it to a flex column that sizes to content instead. */
  .split-card-list .card-inner {
    display: flex !important;
    flex-direction: column !important;
    height: auto !important;
    min-height: 180px !important;
    background: var(--color-surface) !important;
    color: var(--color-text-primary) !important;
  }

  /* Address block and data row: force visible in case flex or opacity rules hide them. */
  .split-card-list .card-address-block,
  .split-card-list .card-data-row {
    display: block !important;
    opacity: 1 !important;
    visibility: visible !important;
  }

  /* ── Marker-click highlight ──
   * Applied for 2 s when a map pin is clicked. The pulse starts from the accent
   * border and fades outward so the user's eye is drawn to the matching card.
   */
  .is-active-highlight {
    border: 2px solid var(--color-primary) !important;
    animation: card-highlight-pulse 0.7s ease-out forwards;
    position: relative;
    z-index: 100;
  }

  @keyframes card-highlight-pulse {
    0%   { box-shadow: 0 0 0 0   color-mix(in srgb, var(--color-accent) 45%, transparent); }
    60%  { box-shadow: 0 0 0 8px color-mix(in srgb, var(--color-accent) 15%, transparent); }
    100% { box-shadow: 0 0 0 12px color-mix(in srgb, var(--color-accent)  0%, transparent); }
  }
</style>
